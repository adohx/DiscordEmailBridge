DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# Optional: restricts the bridge to this guild in addition to the channel above.
DISCORD_GUILD_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

TARGET_EMAIL=
ALLOWED_EMAIL_SENDER=

EMAIL_POLL_INTERVAL_SECONDS=60
STATE_FILE=state.json

# Domain used to build synthetic Message-IDs for Discord->Email messages.
# Looks like an email domain but doesn't need to be a real mailbox.
EMAIL_MESSAGE_ID_DOMAIN=bridge.local

# Whether delete-notification emails include the deleted message's original content.
INCLUDE_DELETED_CONTENT=true
